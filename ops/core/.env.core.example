# Olympus Core Services Environment
# Copy to ops/core/.env.core and edit before running scripts/install-core-services.sh.

OLYMPUS_POSTGRES_DB=olympus
OLYMPUS_POSTGRES_USER=olympus
OLYMPUS_POSTGRES_PASSWORD=change-this-long-random-password
OLYMPUS_POSTGRES_PORT=5432

OLYMPUS_REDIS_PORT=6379

OLYMPUS_MINIO_ROOT_USER=olympusadmin
OLYMPUS_MINIO_ROOT_PASSWORD=change-this-long-random-password
OLYMPUS_MINIO_API_PORT=9000
OLYMPUS_MINIO_CONSOLE_PORT=9001

# Connection strings used by the application after database integration lands.
OLYMPUS_DATABASE_URL=postgresql://olympus:change-this-long-random-password@127.0.0.1:5432/olympus
OLYMPUS_REDIS_URL=redis://127.0.0.1:6379
OLYMPUS_OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
