# Dennco Olympus Command runtime configuration
NODE_ENV=production
PORT=3001

# Admin login
# Set this before exposing the app. The login screen will not accept access until this is configured.
OLYMPUS_ADMIN_USER=admin
# OLYMPUS_ADMIN_ACCESS_CODE=change-this-before-use

# Directory integration
# Use these for NethServer 8 Active Directory / LDAP environments.
OLYMPUS_AUTH_PROVIDER=local
OLYMPUS_DIRECTORY_PROVIDER=none
OLYMPUS_NETHSERVER8_DIRECTORY=false
# OLYMPUS_LDAP_URL=ldaps://directory.example.local:636
# OLYMPUS_LDAP_BIND_DN=
# OLYMPUS_LDAP_SEARCH_BASE=
# OLYMPUS_LDAP_SEARCH_FILTER=(uid={{username}})
# OLYMPUS_LDAP_ADMIN_GROUP_DN=
# OLYMPUS_LDAP_TLS_REJECT_UNAUTHORIZED=true

# Branding
OLYMPUS_PRODUCT_NAME=Dennco Olympus Command
OLYMPUS_SHORT_NAME=OLYMPUS
# OLYMPUS_LOGO_URL=
# OLYMPUS_FAVICON_URL=
OLYMPUS_FOOTER_TEXT=Dennco Olympus Command

# Feature toggles
OLYMPUS_FEATURE_FLIGHTS=true
OLYMPUS_FEATURE_MARITIME=true
OLYMPUS_FEATURE_MONITOR=true
OLYMPUS_FEATURE_DOT=true
OLYMPUS_FEATURE_CYBER=true
OLYMPUS_FEATURE_CSS_INJECTOR=true

# Custom CSS injector. For larger CSS, use systemd override or future admin storage.
# OLYMPUS_CUSTOM_CSS=

# DOT / National traffic feeds
# These should point to GeoJSON-compatible endpoints where possible.
DOT_PROVIDER_MODE=custom
# DOT_NATIONAL_TRAFFIC_GEOJSON_URL=
# DOT_TRAFFIC_GEOJSON_URL=
# DOT_CAMERAS_GEOJSON_URL=
# DOT_ROAD_CLOSURES_GEOJSON_URL=
# DOT_STATE_FEEDS=MI,OH,IN,IL,PA,NY,FL,TX,CA

# Vite build-time DOT fallbacks for static frontend builds.
# VITE_DOT_TRAFFIC_GEOJSON_URL=
# VITE_DOT_CAMERAS_GEOJSON_URL=

# NOAA weather radar overlay
# VITE_NOAA_RADAR_TILE_URL=

# Optional external data/API keys go here.
# AISSTREAM_API_KEY=
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
# MAP_TILES_URL=
